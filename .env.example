# Backend (optional live mint sync): export before `python3 app.py` in backend/
ETHERSCAN_API_KEY=

# Frontend local dev: copy vars below to frontend/.env.development (gitignored) for `npm start`
REACT_APP_ETHERSCAN_API_KEY=
REACT_APP_API_URL=http://localhost:5000
# REACT_APP_DEBUG=true

# Frontend local prod build (optional): copy to frontend/.env.production.local (gitignored)
# or use `npm run build:local` with frontend/.env.production (gitignored).
# Vercel: set these in Project Settings → Environment Variables (Production + Preview).
# Do not commit secret values; `npm run build` reads REACT_APP_* from the environment.
#
# Required on Vercel (secret):
# REACT_APP_ETHERSCAN_API_KEY=<your Etherscan API key>
#
# Recommended on Vercel (public backend URL):
# REACT_APP_API_URL=https://afa-editor.ew.r.appspot.com
#
# Optional:
# REACT_APP_DEBUG=false
