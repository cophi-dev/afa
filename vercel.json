{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/app.py" },
    { "source": "/static/(.*)", "destination": "/frontend/public/static/$1" },
    { "source": "/manifest.json", "destination": "/frontend/public/manifest.json" },
    { "source": "/favicon.ico", "destination": "/frontend/public/favicon.ico" },
    { "source": "/logo.png", "destination": "/frontend/public/logo.png" },
    { "source": "/(.*)", "destination": "/frontend/public/index.html" }
  ]
}
